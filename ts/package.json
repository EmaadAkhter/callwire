{
  "name": "@emaad-ansari/callwire",
  "version": "2.0.1",
  "description": "High-performance, bidirectional RPC over TCP with MessagePack framing — TypeScript/Node.js client & server",
  "main": "dist/index.js",
  "bin": {
    "callwire": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "pretest": "python3 -m pip install --break-system-packages -e ../python",

    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rpc",
    "msgpack",
    "callwire",
    "tcp",
    "ipc"
  ],
  "author": "Emaad Akhter",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testTimeout": 60000,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
